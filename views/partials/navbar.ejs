<aside class="sidebar border-end d-none d-lg-block">
    <div class="px-3">
        <ul class="nav flex-column sidebar-nav">
            <li class="nav-item mb-1">
                <a class="nav-link" href="/" id="nav-create"><i class="bi bi-plus-square me-3"></i>Create New Post</a>
            </li>
            <li class="nav-item mb-1">
                <a class="nav-link" href="/show-all" id="nav-list"><i class="bi bi-list-columns-reverse me-3"></i>All Blog Posts</a>
            </li>
        </ul>
    </div>
</aside>
<script>
    document.addEventListener("DOMContentLoaded", () => {
        const path = window.location.pathname;
        const navCreate = document.getElementById("nav-create");
        const navList = document.getElementById("nav-list");
        
        // Remove active from both first
        navCreate.classList.remove("active");
        navList.classList.remove("active");
        
        if (path === "/show-all" || path.startsWith("/delete/")) {
            navList.classList.add("active");
        } else if (path === "/" || path === "") {
            navCreate.classList.add("active");
        }
    });
</script>