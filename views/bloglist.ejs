<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Create New Blog Post | Admin Dashboard</title>
        <!-- Bootstrap 5 CSS -->
        <link rel="icon" type="image/x-icon" href="d.png">
        <%- include('partials/css') %>
        <style>
            .ck-editor__editable_inline {
                min-height: 400px;
            }
        </style>
    </head>
    <body class="">
        <!-- Top Navigation -->
        <nav class="navbar navbar-expand-lg navbar-light border-bottom fixed-top header-nav">
            <div class="container-fluid px-4">
                <a class="navbar-brand fw-bold custom-brand" href="#">
                <i class="bi bi-layers-half me-2"></i>Nexus<span class="text-dark">CMS</span>
                </a>
                <div class="d-flex align-items-center">
                    <div class="dropdown">
                        <button class="btn btn-light rounded-circle p-2 me-3 position-relative shadow-sm" type="button" data-bs-toggle="dropdown">
                        <i class="bi bi-bell"></i>
                        <span class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle">
                        <span class="visually-hidden">New alerts</span>
                        </span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                            <li><a class="dropdown-item" href="#">No new notifications</a></li>
                        </ul>
                    </div>
                    <div class="dropdown">
                        <button class="btn btn-white d-flex align-items-center dropdown-toggle shadow-sm rounded-pill p-1 pe-3 border" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <img src="https://ui-avatars.com/api/?name=Admin+User&background=0D8ABC&color=fff" alt="User" class="rounded-circle me-2" width="32" height="32">
                        <span class="small fw-medium">Admin User</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                            <li><a class="dropdown-item" href="#"><i class="bi bi-person me-2"></i>Profile</a></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-gear me-2"></i>Settings</a></li>
                            <li>
                                <hr class="dropdown-divider">
                            </li>
                            <li><a class="dropdown-item text-danger" href="#"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </nav>
        <!-- Main Layout -->
        <div class="d-flex pt-5 mt-4">
            <!-- Sidebar -->
            <%- include('partials/navbar') %>
            <!-- Main Content -->
            
            <main class="main-content flex-grow-1 p-4 pb-5">
                <div class="container-fluid max-w-1200 mx-auto">
                    
                    <!-- Breadcrumb & Header -->
                    <div class="d-flex justify-content-between align-items-end mb-4 flex-wrap gap-3">
                        <div>
                            <nav aria-label="breadcrumb">
                                <ol class="breadcrumb mb-2 small">
                                    <li class="breadcrumb-item"><a href="#" class="text-decoration-none text-muted">Dashboard</a></li>
                                    <li class="breadcrumb-item active" aria-current="page">Posts</li>
                                </ol>
                            </nav>
                            <h1 class="h3 mb-0 fw-bold page-title text-dark">List all post</h1>
                        </div>
                        
                        <!-- Action Buttons -->
                        <div class="action-buttons d-flex gap-2">
                            <a href="" class="btn btn-primary px-4 fw-medium shadow-sm d-flex align-items-center">
                                <i class="bi bi-plus-lg me-2 small"></i>Create New Post
                            </a>
                        </div>
                    </div>

                    <!-- Posts Grid -->
                    <div class="row g-4">
                        <!-- Post Card 1 -->
                        <div class="col-md-6 col-xl-4">
                            <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden">
                                <div class="position-relative">
                                    <img src="https://images.unsplash.com/photo-1498050108023-c5249f4df085?w=500&amp;h=300&amp;fit=crop" class="card-img-top object-fit-cover" alt="Post Image" style="height: 200px;">
                                    <span class="position-absolute top-0 end-0 m-3 badge bg-success text-white rounded-pill px-3 py-2 fw-medium shadow-sm">Published</span>
                                </div>
                                <div class="card-body p-4 d-flex flex-column">
                                    <div class="d-flex align-items-center mb-3">
                                        <span class="badge custom-badge rounded-pill me-2 px-3 py-1">Technology</span>
                                        <small class="text-muted fw-medium"><i class="bi bi-calendar3 me-1"></i> Oct 24, 2023</small>
                                    </div>
                                    <h5 class="card-title fw-bold text-dark mb-3" style="font-family: var(--font-serif); line-height: 1.4;">The Future of AI in Web Development</h5>
                                    <p class="card-text text-muted small mb-4 flex-grow-1">Explore how artificial intelligence is shaping the modern web development landscape and what it means for developers in the coming years.</p>
                                    <div class="d-flex justify-content-between align-items-center border-top pt-3 border-light-subtle">
                                        <div class="d-flex align-items-center">
                                            <img src="https://ui-avatars.com/api/?name=Admin+User&amp;background=0D8ABC&amp;color=fff" alt="Author" class="rounded-circle me-2" width="28" height="28">
                                            <small class="fw-medium text-dark">Admin User</small>
                                        </div>
                                        <div class="d-flex gap-2">
                                            <a href="blog-details.html" class="btn btn-sm btn-light rounded-circle text-primary border-0 shadow-sm custom-action-btn" title="View Details"><i class="bi bi-eye"></i></a>
                                            <a href="#" class="btn btn-sm btn-light rounded-circle text-secondary border-0 shadow-sm custom-action-btn" title="Edit Post"><i class="bi bi-pencil"></i></a>
                                            <button class="btn btn-sm btn-light rounded-circle text-danger border-0 shadow-sm custom-action-btn" title="Delete Post"><i class="bi bi-trash"></i></button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Post Card 2 -->
                        <div class="col-md-6 col-xl-4">
                            <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden">
                                <div class="position-relative">
                                    <img src="https://images.unsplash.com/photo-1561070791-2526d30994b5?w=500&amp;h=300&amp;fit=crop" class="card-img-top object-fit-cover" alt="Post Image" style="height: 200px;">
                                    <span class="position-absolute top-0 end-0 m-3 badge bg-secondary text-white rounded-pill px-3 py-2 fw-medium shadow-sm">Draft</span>
                                </div>
                                <div class="card-body p-4 d-flex flex-column">
                                    <div class="d-flex align-items-center mb-3">
                                        <span class="badge custom-badge rounded-pill me-2 px-3 py-1" style="background-color: #e0e7ff; color: #4338ca; border-color: #c7d2fe;">Design</span>
                                        <small class="text-muted fw-medium"><i class="bi bi-calendar3 me-1"></i> Oct 20, 2023</small>
                                    </div>
                                    <h5 class="card-title fw-bold text-dark mb-3" style="font-family: var(--font-serif); line-height: 1.4;">Mastering Glassmorphism UI Interfaces</h5>
                                    <p class="card-text text-muted small mb-4 flex-grow-1">A comprehensive guide on creating stunning frosted glass effects that elevate your user interfaces to a premium level.</p>
                                    <div class="d-flex justify-content-between align-items-center border-top pt-3 border-light-subtle">
                                        <div class="d-flex align-items-center">
                                            <img src="https://ui-avatars.com/api/?name=Jane+Doe&amp;background=10B981&amp;color=fff" alt="Author" class="rounded-circle me-2" width="28" height="28">
                                            <small class="fw-medium text-dark">Jane Doe</small>
                                        </div>
                                        <div class="d-flex gap-2">
                                            <a href="blog-details.html" class="btn btn-sm btn-light rounded-circle text-primary border-0 shadow-sm custom-action-btn" title="View Details"><i class="bi bi-eye"></i></a>
                                            <a href="#" class="btn btn-sm btn-light rounded-circle text-secondary border-0 shadow-sm custom-action-btn" title="Edit Post"><i class="bi bi-pencil"></i></a>
                                            <button class="btn btn-sm btn-light rounded-circle text-danger border-0 shadow-sm custom-action-btn" title="Delete Post"><i class="bi bi-trash"></i></button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Post Card 3 -->
                        <div class="col-md-6 col-xl-4">
                            <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden">
                                <div class="position-relative">
                                    <img src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=500&amp;h=300&amp;fit=crop" class="card-img-top object-fit-cover" alt="Post Image" style="height: 200px;">
                                    <span class="position-absolute top-0 end-0 m-3 badge bg-info text-white rounded-pill px-3 py-2 fw-medium shadow-sm">Scheduled</span>
                                </div>
                                <div class="card-body p-4 d-flex flex-column">
                                    <div class="d-flex align-items-center mb-3">
                                        <span class="badge custom-badge rounded-pill me-2 px-3 py-1" style="background-color: #dcfce7; color: #15803d; border-color: #bbf7d0;">Business</span>
                                        <small class="text-muted fw-medium"><i class="bi bi-calendar3 me-1"></i> Oct 18, 2023</small>
                                    </div>
                                    <h5 class="card-title fw-bold text-dark mb-3" style="font-family: var(--font-serif); line-height: 1.4;">Scaling Your Startup in 2024</h5>
                                    <p class="card-text text-muted small mb-4 flex-grow-1">Key strategies and actionable insights for growing your technology startup in an increasingly competitive marketplace.</p>
                                    <div class="d-flex justify-content-between align-items-center border-top pt-3 border-light-subtle">
                                        <div class="d-flex align-items-center">
                                            <img src="https://ui-avatars.com/api/?name=John+Smith&amp;background=F59E0B&amp;color=fff" alt="Author" class="rounded-circle me-2" width="28" height="28">
                                            <small class="fw-medium text-dark">John Smith</small>
                                        </div>
                                        <div class="d-flex gap-2">
                                            <a href="blog-details.html" class="btn btn-sm btn-light rounded-circle text-primary border-0 shadow-sm custom-action-btn" title="View Details"><i class="bi bi-eye"></i></a>
                                            <a href="#" class="btn btn-sm btn-light rounded-circle text-secondary border-0 shadow-sm custom-action-btn" title="Edit Post"><i class="bi bi-pencil"></i></a>
                                            <button class="btn btn-sm btn-light rounded-circle text-danger border-0 shadow-sm custom-action-btn" title="Delete Post"><i class="bi bi-trash"></i></button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Pagination -->
                    <nav class="mt-5" aria-label="Page navigation">
                        <ul class="pagination justify-content-center">
                            <li class="page-item disabled"><a class="page-link border-0 shadow-sm rounded-start-pill bg-white text-muted px-3" href="#">Previous</a></li>
                            <li class="page-item active"><a class="page-link border-0 shadow-sm bg-primary text-white" href="#" style="background: var(--accent-gradient);">1</a></li>
                            <li class="page-item"><a class="page-link border-0 shadow-sm bg-white text-dark" href="#">2</a></li>
                            <li class="page-item"><a class="page-link border-0 shadow-sm bg-white text-dark" href="#">3</a></li>
                            <li class="page-item"><a class="page-link border-0 shadow-sm rounded-end-pill bg-white text-dark px-3" href="#">Next</a></li>
                        </ul>
                    </nav>

                </div>
            </main>

        </div>
        <!-- Bootstrap 5 JS Bundle with Popper -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    </body>
</html>