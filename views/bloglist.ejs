<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Create New Blog Post | Admin Dashboard</title>
        <link rel="icon" type="image/x-icon" href="d.png">
        <%- include('partials/css') %>
        <style>
            .ck-editor__editable_inline {
                min-height: 400px;
            }
        </style>
    </head>
    <body>
        <!-- Top Navigation -->
        <nav class="navbar navbar-expand-lg navbar-light fixed-top header-nav">
            <div class="container-fluid px-4">
                <a class="navbar-brand" href="/">
                    <i class="bi bi-layers-half me-2"></i>Nexus<span>CMS</span>
                </a>
                <div class="d-flex align-items-center">
                    <div class="dropdown me-3">
                        <button class="btn btn-light rounded-circle p-2 position-relative border-0" type="button" data-bs-toggle="dropdown">
                            <i class="bi bi-bell"></i>
                            <span class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle">
                                <span class="visually-hidden">New alerts</span>
                            </span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-2">
                            <li><a class="dropdown-item py-2 small" href="#">No new notifications</a></li>
                        </ul>
                    </div>
                    <div class="dropdown">
                        <button class="btn btn-light d-flex align-items-center dropdown-toggle rounded-pill p-1 pe-3 border" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <img src="https://ui-avatars.com/api/?name=Admin+User&background=f4f4f5&color=09090b" alt="User" class="rounded-circle me-2" width="28" height="28">
                            <span class="small fw-medium">Admin User</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-2">
                            <li><a class="dropdown-item py-2 small" href="#"><i class="bi bi-person me-2"></i>Profile</a></li>
                            <li><a class="dropdown-item py-2 small" href="#"><i class="bi bi-gear me-2"></i>Settings</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item py-2 small text-danger" href="#"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </nav>

        <!-- Main Layout -->
        <div class="d-flex pt-5 mt-3">
            <!-- Sidebar -->
            <%- include('partials/navbar') %>
            
            <!-- Main Content -->
            <main class="main-content flex-grow-1 p-4 pb-5">
                <div class="container-fluid max-w-1200 mx-auto">
                    <!-- Breadcrumb & Header -->
                    <div class="d-flex justify-content-between align-items-end mb-4 flex-wrap gap-3">
                        <div>
                            <nav aria-label="breadcrumb">
                                <ol class="breadcrumb mb-2">
                                    <li class="breadcrumb-item"><a href="#" class="text-decoration-none">Dashboard</a></li>
                                    <li class="breadcrumb-item active" aria-current="page">Posts</li>
                                </ol>
                            </nav>
                            <h1 class="h3 mb-0 page-title">All Blog Posts</h1>
                        </div>
                        
                        <div class="action-buttons">
                            <a href="/" class="btn btn-primary">
                                <i class="bi bi-plus-lg me-1"></i> Create New Post
                            </a>
                        </div>
                    </div>

                    <!-- Posts Grid -->
                    <div class="row g-4">
                        <% if (blogs && blogs.length > 0) { %>
                            <% blogs.forEach(oneblog => { %>
                            <div class="col-md-6 col-xl-4">
                                <div class="card h-100">
                                    <div class="card-body d-flex flex-column justify-content-between p-4">
                                        <div>
                                            <div class="d-flex align-items-center mb-3">
                                                <small class="text-muted fw-medium">
                                                    <i class="bi bi-calendar3 me-1.5"></i>
                                                    <% if (oneblog.createdAt) { %>
                                                        <%= new Date(oneblog.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                                                    <% } else { %>
                                                        Just now
                                                    <% } %>
                                                </small>
                                            </div>
                                            <h5 class="card-title fw-bold text-dark mb-2" style="line-height: 1.4; font-size: 1.1rem;"><%= oneblog.title %></h5>
                                            <p class="card-text text-muted small mb-4 flex-grow-1" style="line-height: 1.5;"><%= oneblog.shortDescription %></p>
                                        </div>
                                        <div class="d-flex justify-content-between align-items-center border-top pt-3 mt-auto" style="border-color: #f4f4f5 !important;">
                                            <div class="d-flex align-items-center">
                                                <img src="https://ui-avatars.com/api/?name=Admin+User&background=f4f4f5&color=09090b" alt="Author" class="rounded-circle me-2" width="24" height="24">
                                                <small class="fw-medium text-dark" style="font-size: 0.8rem;">Admin User</small>
                                            </div>
                                            <div>
                                                <a href="/delete/<%= oneblog._id %>" class="custom-action-btn" title="Delete Post">
                                                    <i class="bi bi-trash"></i>
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <% }) %>
                        <% } else { %>
                            <div class="col-12">
                                <div class="card py-5 text-center">
                                    <div class="card-body">
                                        <i class="bi bi-folder2-open text-muted fs-1 mb-3"></i>
                                        <h5 class="fw-semibold mb-2">No posts found</h5>
                                        <p class="text-muted small mb-4">Start by creating your very first classic blog post.</p>
                                        <a href="/" class="btn btn-primary">
                                            <i class="bi bi-plus-lg me-1"></i> Create Post
                                        </a>
                                    </div>
                                </div>
                            </div>
                        <% } %>
                    </div>

                    <!-- Pagination -->
                    <% if (blogs && blogs.length > 0) { %>
                    <nav class="mt-5" aria-label="Page navigation">
                        <ul class="pagination justify-content-center">
                            <li class="page-item disabled"><a class="page-link rounded-start-pill px-3" href="#">Previous</a></li>
                            <li class="page-item active"><a class="page-link" href="#">1</a></li>
                            <li class="page-item"><a class="page-link" href="#">2</a></li>
                            <li class="page-item"><a class="page-link" href="#">3</a></li>
                            <li class="page-item"><a class="page-link rounded-end-pill px-3" href="#">Next</a></li>
                        </ul>
                    </nav>
                    <% } %>
                </div>
            </main>
        </div>
        <!-- Bootstrap 5 JS Bundle with Popper -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    </body>
</html>