<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Create New Blog Post | Admin Dashboard</title>
        <link rel="icon" type="image/x-icon" href="d.png">
        <%- include('partials/css') %>
        <style>
            .ck-editor__editable_inline {
                min-height: 400px;
            }
        </style>
    </head>
    <body>
        <!-- Top Navigation -->
        <nav class="navbar navbar-expand-lg navbar-light fixed-top header-nav">
            <div class="container-fluid px-4">
                <a class="navbar-brand" href="/">
                    <i class="bi bi-layers-half me-2"></i>Nexus<span>CMS</span>
                </a>
                <div class="d-flex align-items-center">
                    <div class="dropdown me-3">
                        <button class="btn btn-light rounded-circle p-2 position-relative border-0" type="button" data-bs-toggle="dropdown">
                            <i class="bi bi-bell"></i>
                            <span class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle">
                                <span class="visually-hidden">New alerts</span>
                            </span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-2">
                            <li><a class="dropdown-item py-2 small" href="#">No new notifications</a></li>
                        </ul>
                    </div>
                    <div class="dropdown">
                        <button class="btn btn-light d-flex align-items-center dropdown-toggle rounded-pill p-1 pe-3 border" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <img src="https://ui-avatars.com/api/?name=Admin+User&background=f4f4f5&color=09090b" alt="User" class="rounded-circle me-2" width="28" height="28">
                            <span class="small fw-medium">Admin User</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-2">
                            <li><a class="dropdown-item py-2 small" href="#"><i class="bi bi-person me-2"></i>Profile</a></li>
                            <li><a class="dropdown-item py-2 small" href="#"><i class="bi bi-gear me-2"></i>Settings</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item py-2 small text-danger" href="#"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </nav>

        <!-- Main Layout -->
        <div class="d-flex pt-5 mt-3">
            <!-- Sidebar -->
            <%- include('partials/navbar') %>
            
            <!-- Main Content -->
            <main class="main-content flex-grow-1 p-4 pb-5">
                <div class="container-fluid max-w-1200 mx-auto">
                    <!-- Breadcrumb & Header -->
                    <div class="d-flex justify-content-between align-items-end mb-4 flex-wrap gap-3">
                        <div>
                            <nav aria-label="breadcrumb">
                                <ol class="breadcrumb mb-2">
                                    <li class="breadcrumb-item"><a href="#" class="text-decoration-none">Dashboard</a></li>
                                    <li class="breadcrumb-item active" aria-current="page">Posts</li>
                                </ol>
                            </nav>
                            <h1 class="h3 mb-0 page-title">Create New Post</h1>
                        </div>
                        <div class="action-buttons">
                            <a href="/show-all" class="btn btn-light">
                                <i class="bi bi-list-task me-1"></i> List All Posts
                            </a>
                        </div>
                    </div>

                    <!-- Form -->
                    <form method="POST" id="submitBlogForm" action="/submit-form" enctype="multipart/form-data">
                        <div id="alertMessage" class="alert d-none" role="alert"></div>
                        
                        <div class="row g-4">
                            <div class="col-lg-12">
                                <!-- Basic Info -->
                                <div class="card mb-4">
                                    <div class="card-body p-4 p-xl-5">
                                        <div class="mb-4">
                                            <label class="form-label">Blog Title <span class="text-danger">*</span></label>
                                            <input type="text" name="blogTitle" class="form-control title-input" id="blogTitle" placeholder="Enter a captivating title..." required>
                                        </div>
                                        <div class="mb-4">
                                            <label for="slugUrl" class="form-label">Permalink / Slug URL <span class="text-danger">*</span></label>
                                            <div class="input-group">
                                                <span class="input-group-text bg-light text-muted border-end-0 small">/posts/</span>
                                                <input name="slugUrl" type="text" class="form-control border-start-0" id="slugUrl" placeholder="auto-generated-slug" required>
                                            </div>
                                        </div>
                                        <div class="mb-0">
                                            <div class="d-flex justify-content-between align-items-center mb-1">
                                                <label for="shortDescription" class="form-label mb-0">Short Description / Excerpt <span class="text-danger">*</span></label>
                                                <span class="text-muted small" id="charCount">0 / 160</span>
                                            </div>
                                            <textarea name="shortDescription" class="form-control" id="shortDescription" rows="3" placeholder="Write a brief summary of the post..." maxlength="160" required></textarea>
                                        </div>
                                    </div>
                                </div>

                                <!-- Rich Text Content -->
                                <div class="card mb-4">
                                    <div class="card-header">
                                        <h5 class="mb-0 fs-6 fw-semibold">Content</h5>
                                    </div>
                                    <div class="card-body">
                                        <textarea name="blogContent" class="form-control rich-editor" id="blogContent" rows="15" placeholder="Write your amazing content here..."></textarea>
                                    </div>
                                </div>

                                <!-- SEO Section -->
                                <div class="card mb-4">
                                    <div class="card-header d-flex justify-content-between align-items-center">
                                        <h5 class="mb-0 fs-6 fw-semibold">Search Engine Optimization</h5>
                                        <span class="badge custom-badge rounded-pill">SEO Assistant</span>
                                    </div>
                                    <div class="card-body">
                                        <div class="mb-3">
                                            <label for="metaTitle" class="form-label">Meta Title</label>
                                            <input name="metaTitle" type="text" class="form-control" id="metaTitle" placeholder="SEO optimized title">
                                        </div>
                                        <div class="mb-3">
                                            <label for="metaDescription" class="form-label">Meta Description</label>
                                            <textarea name="metaDescription" class="form-control" id="metaDescription" rows="2" placeholder="SEO optimized description"></textarea>
                                        </div>
                                        <div>
                                            <label for="metaKeywords" class="form-label">Meta Keywords</label>
                                            <input type="text" class="form-control" id="metaKeywords" placeholder="keyword1, keyword2, keyword3">
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Submit Section -->
                        <div class="d-flex justify-content-end gap-3 mt-2">
                            <a href="/show-all" class="btn btn-light px-4">Cancel</a>
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="bi bi-send-fill me-1 small"></i> Publish Post
                            </button>
                        </div>
                    </form>
                </div>
            </main>
        </div>

        <!-- Bootstrap 5 JS Bundle with Popper -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

        <!-- CKEditor 5 Super Build for HTML Support -->
        <script src="https://cdn.ckeditor.com/ckeditor5/39.0.1/super-build/ckeditor.js"></script>
        
        <script>
            // Form submission logic with robust redirect handling
            document.getElementById("submitBlogForm").addEventListener("submit", async event =>  {
                event.preventDefault();
                const alertBox = document.getElementById("alertMessage");
                const submitBtn = event.target.querySelector('button[type="submit"]');
                
                // Show loading state
                const originalBtnHtml = submitBtn.innerHTML;
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span> Publishing...';
                
                const formData = new FormData(event.target);
                
                try {
                    const response = await fetch(event.target.action, {
                        method: "POST", 
                        body: formData
                    });
                    
                    if (response.redirected) {
                        window.location.href = response.url;
                        return;
                    }
                    
                    const data = await response.json();
                    
                    if(data.errors) {
                        let html_str = "";
                        data.errors.map(err => { 
                            html_str += "<p class='mb-1'><i class='bi bi-exclamation-circle me-2'></i>" + err.msg + "</p>";
                        });
                        alertBox.classList.remove("d-none", "alert-success");
                        alertBox.classList.add("alert-danger");
                        alertBox.innerHTML = html_str;
                        
                        // Reset button
                        submitBtn.disabled = false;
                        submitBtn.innerHTML = originalBtnHtml;
                    } else {
                        alertBox.classList.remove("d-none", "alert-danger");
                        alertBox.classList.add('alert-success');
                        alertBox.innerHTML = "<i class='bi bi-check-circle me-2'></i>Blog created successfully! Redirecting...";
                        
                        setTimeout(() => {
                            window.location.href = "/show-all";
                        }, 800);
                    }
                } catch(err) {
                    console.error("Submission error:", err);
                    alertBox.classList.remove("d-none", "alert-success");
                    alertBox.classList.add("alert-danger");
                    alertBox.innerHTML = "<p class='mb-0'><i class='bi bi-exclamation-triangle me-2'></i>Failed to publish blog post. Please try again.</p>";
                    
                    // Reset button
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalBtnHtml;
                }
                
                window.scrollTo({
                    top: 0,
                    behavior: "smooth"
                });
            });

            // Auto-slug Generation Logic
            const titleInput = document.getElementById("blogTitle");
            const slugInput = document.getElementById("slugUrl");
            let isSlugManuallyEdited = false;

            slugInput.addEventListener("input", () => {
                isSlugManuallyEdited = true;
            });

            titleInput.addEventListener("input", () => {
                if (!isSlugManuallyEdited) {
                    const slug = titleInput.value
                        .toLowerCase()
                        .trim()
                        .replace(/[^\w\s-]/g, '') // remove non-word chars except space/hyphen
                        .replace(/[\s_]+/g, '-')   // replace spaces/underscores with hyphen
                        .replace(/^-+|-+$/g, '');  // remove leading/trailing hyphens
                    slugInput.value = slug;
                }
            });

            // Character Counter Logic for Excerpt
            const shortDescInput = document.getElementById("shortDescription");
            const charCountSpan = document.getElementById("charCount");
            shortDescInput.addEventListener("input", () => {
                charCountSpan.textContent = `${shortDescInput.value.length} / 160`;
            });

            // Initialize CKEditor 5
            CKEDITOR.ClassicEditor
                .create(document.querySelector('#blogContent'), {
                    plugins: [
                        'Autoformat', 'BlockQuote', 'Bold', 'Heading',
                        'Indent', 'Italic', 'Link', 'List', 'Paragraph',
                        'SourceEditing', 'GeneralHtmlSupport', 'Underline', 'Strikethrough'
                    ],
                    toolbar: {
                        items: [
                            'sourceEditing', '|',
                            'heading', '|',
                            'bold', 'italic', 'underline', 'strikethrough', '|',
                            'bulletedList', 'numberedList', '|',
                            'outdent', 'indent', '|',
                            'link', 'blockQuote', '|',
                            'undo', 'redo'
                        ]
                    },
                    htmlSupport: {
                        allow: [
                            {
                                name: /.*/,
                                attributes: true,
                                classes: true,
                                styles: true
                            }
                        ]
                    }
                })
                .catch(error => {
                    console.error('Error initializing CKEditor:', error);
                });
        </script>
    </body>
</html>